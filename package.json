{
  "name": "microblog",
  "version": "1.0.0",
  "description": "A microblog service",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "test": "pnpm --filter frontend test",
    "test:backend": "pnpm --filter backend test",
    "test:infra": "pnpm run build:backend && pnpm --filter infra test",
    "generate:types": "openapi-typescript openapi.yaml -o shared/types/api.ts",
    "deploy:all": "pnpm run build && pnpm run build:backend && cd infra && pnpm cdk deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  },
  "pnpm": {
    "overrides": {
      "@smithy/types": "^4.13.0"
    }
  }
}
